# JobPulse AI - Production Environment Configuration

# Security
API_KEY=changeme-secure-production-key

# Database
POSTGRES_USER=jobpulse
POSTGRES_PASSWORD=jobpulse_password
POSTGRES_DB=jobpulse
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://jobpulse:jobpulse_password@postgres:5432/jobpulse

# API Configuration
API_ENV=production
LOG_LEVEL=INFO
PRELOAD_EMBEDDINGS=true
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Dashboard Client Configuration
# Internal docker-network URL for SSR or direct API access
API_URL=http://api:8000/api/v1
REQUEST_TIMEOUT=30
